rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only access their own data
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // User profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Products (personal per user)
    match /products/{userId}/items/{productId} {
      allow read, write: if isOwner(userId);
    }

    // Movements log (personal per user)
    match /movements/{userId}/log/{movementId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      // No update/delete on movements (audit trail)
    }

    // Count tasks (personal per user)
    match /countTasks/{userId}/tasks/{taskId} {
      allow read, write: if isOwner(userId);
    }
  }
}
